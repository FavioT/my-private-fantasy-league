# Configuración de ESPN Fantasy API
# Copia este archivo a .env y completa con tus datos reales

# ID de tu liga de ESPN Fantasy Basketball
LEAGUE_ID=your_league_id_here

# Año de la temporada
LEAGUE_YEAR=2026

# Cookie ESPN_S2 (obtener desde las cookies de tu navegador en ESPN.com)
ESPN_S2=your_espn_s2_cookie_here

# Cookie SWID (obtener desde las cookies de tu navegador en ESPN.com)
SWID={your_swid_here}

# Modo de datos (True para mock, False para datos reales de ESPN API)
USE_MOCK=False
